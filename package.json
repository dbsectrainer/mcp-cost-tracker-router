{
  "name": "mcp-cost-tracker-router",
  "version": "1.0.0",
  "description": "Real-time cost awareness for MCP agent workflows",
  "author": "dbsectrainer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dbsectrainer/mcp-cost-tracker-router.git"
  },
  "homepage": "https://github.com/dbsectrainer/mcp-cost-tracker-router#readme",
  "type": "module",
  "bin": {
    "mcp-cost-tracker-router": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    ".env.example"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "cost-tracking",
    "llm-costs"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "dev": "tsx src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^12.8.0",
    "express": "^5.2.1",
    "js-tiktoken": "^1.0.21",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.0.0",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.0",
    "@types/yargs": "^17.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0",
    "yargs": "^18.0.0"
  }
}
